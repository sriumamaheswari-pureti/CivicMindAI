# CivicMind AI Backend Environment Variables Template
# Copy this file to '.env' and fill in your actual credentials.

# The port the backend server will run on in development
PORT=5000

# Your MongoDB Atlas Connection String
# Example: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/civicmind?retryWrites=true&w=majority

# Your Google Gemini AI API key for the chatbot classification
GEMINI_API_KEY=your_gemini_api_key_here
